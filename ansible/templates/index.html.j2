<!DOCTYPE html>
<html>
<head>
  <title>{{ site_title }}</title>
  <style>
    body { font-family: sans-serif; padding: 40px; background: #f5f5f5; }
    .box { background: white; padding: 30px; border-radius: 8px; max-width: 600px; }
    h1 { color: #2c3e50; }
  </style>
</head>
<body>
  <div class="box">
    <h1>🚀 {{ site_title }}</h1>
    <p><strong>Hôte :</strong> {{ ansible_hostname }}</p>
    <p><strong>Version :</strong> {{ app_version }}</p>
    <p><strong>Déployé par :</strong> Ansible via Jenkins</p>
  </div>
</body>
</html>
